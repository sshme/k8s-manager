{
  "schemaVersion": "k8s-manager.plugin/v1",
  "id": "observability.prometheus-monitoring",
  "name": "Добавление Prometheus-мониторинга",
  "version": "0.1.0",
  "category": "observability",
  "description": "Автоматически подключает сбор метрик Prometheus к выбранному Deployment, настраивает Service/ServiceMonitor и поднимает managed Prometheus UI, доступный через port-forward.",
  "runtime": {
    "type": "exec",
    "entrypoint": "prometheus-monitoring"
  },
  "commands": [
    {
      "name": "plan",
      "description": "Анализирует Deployment и показывает план изменений"
    },
    {
      "name": "apply",
      "description": "Применяет аннотации, Service и ServiceMonitor"
    }
  ],
  "parameters": [
    {"name": "deployment", "flag": "--deployment", "required": false, "description": "Целевой Deployment; если не задан, выбирается интерактивно"},
    {"name": "namespace", "flag": "--namespace", "required": false, "description": "Namespace Kubernetes"},
    {"name": "metricsPath", "flag": "--metrics-path", "default": "/metrics", "description": "HTTP path endpoint метрик"},
    {"name": "port", "flag": "--port", "required": false, "description": "Порт метрик; если не задан, определяется автоматически"},
    {"name": "scrapeInterval", "flag": "--scrape-interval", "default": "30s", "description": "Интервал scrape для ServiceMonitor и managed Prometheus"},
    {"name": "prometheusNamespace", "flag": "--prometheus-namespace", "default": "monitoring", "description": "Namespace для managed Prometheus"},
    {"name": "prometheusName", "flag": "--prometheus-name", "default": "k8s-manager-prometheus", "description": "Имя managed Prometheus ресурсов"},
    {"name": "prometheusImage", "flag": "--prometheus-image", "default": "prom/prometheus:v2.55.1", "description": "Container image для managed Prometheus"},
    {"name": "skipPrometheusInstall", "flag": "--skip-prometheus-install", "default": "false", "description": "Не создавать managed Prometheus UI"}
  ],
  "kubernetes": {
    "reads": ["deployments", "services", "customresourcedefinitions", "namespaces"],
    "writes": ["deployments", "services", "servicemonitors.monitoring.coreos.com", "namespaces", "serviceaccounts", "configmaps", "clusterroles", "clusterrolebindings"]
  }
}
